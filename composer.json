{
  "name": "uninest/lms",
  "description": "Uninest LMS — Plain PHP+MySQL Module-Based MVC Boilerplate",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8000 -t public"
    ],
    "start": [
      "@serve"
    ],
    "check:functions": [
      "@php scripts/check_functions.php"
    ],
    "make:crud": [
      "@php scripts/make_crud.php"
    ]
  },
  "autoload": {
    "files": [
      "core/helpers.php"
    ]
  }
}
